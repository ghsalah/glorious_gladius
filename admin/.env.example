# Copy to `.env` for local development (never commit real secrets).

# Django API (see glorious_gladius/backend)
VITE_API_URL=http://127.0.0.1:8000

# Google Maps JavaScript API — enable Maps JavaScript API on this key.
VITE_GOOGLE_MAPS_API_KEY=
# Optional: set to "true" to draw routes along roads (also enable Directions API + billing on the key).
# If unset, routes are straight lines between stops (reliable).
# VITE_USE_ROAD_DIRECTIONS=true
# Optional: vector map / Advanced Marker support
# VITE_GOOGLE_MAPS_MAP_ID=
